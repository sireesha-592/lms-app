{
  "name": "lms-admin",
  "version": "1.0.0",
  "description": "CodeMedha Admin Desktop Application",
  "main": "main.js",
  "author": "CodeMedha",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.codemedha.admin",
    "productName": "CodeMedha Admin Panel",
    "copyright": "Copyright © 2025 CodeMedha",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "splash.html",
      "icons/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icons/icon.ico",
      "artifactName": "CodeMedha-Admin-Setup-${version}.${ext}",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CodeMedha Admin",
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "installerHeaderIcon": "icons/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icons/icon.png",
      "category": "Education"
    },
    "forceCodeSigning": false
  }
}
